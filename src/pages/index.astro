---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="株式会社トミザワ | 開発環境準備中" description="株式会社トミザワ ランディングページの開発環境です。">
  <main class="flex min-h-screen items-center justify-center px-6 py-20">
    <section class="w-full max-w-3xl rounded-3xl border border-slate-200 bg-white p-10 shadow-sm">
      <p class="text-sm font-medium tracking-[0.2em] text-slate-500 uppercase">Tomizawa LP Project</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">
        開発環境の初期セットアップが完了しました
      </h1>
      <p class="mt-4 text-base leading-7 text-slate-600">
        このページは現在プレースホルダーです。Canva素材と構成情報を確認後、各セクションをコンポーネント分割した本実装へ進みます。
      </p>
      <div class="mt-8 flex flex-wrap gap-3 text-sm text-slate-600">
        <span class="rounded-full bg-slate-100 px-4 py-2">Astro</span>
        <span class="rounded-full bg-slate-100 px-4 py-2">Tailwind CSS</span>
        <span class="rounded-full bg-slate-100 px-4 py-2">Alpine.js</span>
        <span class="rounded-full bg-slate-100 px-4 py-2">pnpm</span>
        <span class="rounded-full bg-slate-100 px-4 py-2">Netlify</span>
      </div>
    </section>
  </main>
</BaseLayout>
