---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSectionOld from '../components/HeroSectionOld.astro';
import HeroSection from '../components/HeroSection.astro';
import ProblemSectionOld from '../components/ProblemSectionOld.astro';
import ProblemSection from '../components/ProblemSection.astro';
---

<BaseLayout title="Before / After 比較">

  <!-- ヘッダー -->
  <div class="sticky top-0 z-50 flex items-center justify-between bg-slate-900 px-6 py-3 text-white shadow-lg">
    <span class="text-sm font-bold tracking-wide">Before / After 比較ビュー</span>
    <a href="/" class="rounded bg-slate-700 px-4 py-1.5 text-xs font-medium hover:bg-slate-600">← 本番に戻る</a>
  </div>

  <div
    x-data="{ section: 'hero' }"
    class="flex flex-col"
    style="height: calc(100vh - 48px);"
  >
    <!-- タブ切替 -->
    <div class="flex gap-1 bg-slate-700 px-4 pt-3 pb-0 shrink-0">
      <button
        @click="section = 'hero'"
        :class="section === 'hero' ? 'bg-white text-slate-900' : 'text-slate-300 hover:text-white'"
        class="rounded-t px-5 py-2 text-xs font-bold transition-colors"
      >Hero（ファーストビュー）</button>
      <button
        @click="section = 'problem'"
        :class="section === 'problem' ? 'bg-white text-slate-900' : 'text-slate-300 hover:text-white'"
        class="rounded-t px-5 py-2 text-xs font-bold transition-colors"
      >Problem（悩みセクション）</button>
    </div>

    <!-- 比較エリア -->
    <div class="flex flex-1 gap-2 overflow-hidden bg-slate-300 p-2">

      <!-- 左: Before -->
      <div class="flex flex-col overflow-hidden rounded border border-slate-300 bg-white" style="width: 50%; max-width: 1440px;">
        <div class="shrink-0 bg-rose-600 py-2 text-center text-xs font-bold text-white tracking-widest">BEFORE</div>
        <div class="flex-1 overflow-y-auto">
          <div x-show="section === 'hero'"><HeroSectionOld /></div>
          <div x-show="section === 'problem'"><ProblemSectionOld /></div>
        </div>
      </div>

      <!-- 右: After -->
      <div class="flex flex-col overflow-hidden rounded border border-slate-300 bg-white" style="width: 50%; max-width: 1440px;">
        <div class="shrink-0 bg-blue-600 py-2 text-center text-xs font-bold text-white tracking-widest">AFTER</div>
        <div class="flex-1 overflow-y-auto">
          <div x-show="section === 'hero'"><HeroSection /></div>
          <div x-show="section === 'problem'"><ProblemSection /></div>
        </div>
      </div>

    </div>
  </div>

</BaseLayout>
