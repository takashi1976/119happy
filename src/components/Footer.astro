---
const navItems = [
  { label: 'サービス内容', href: '#service' },
  { label: '施工実績', href: '#works' },
  { label: '選ばれる理由', href: '#reason' },
  { label: 'お問い合わせ', href: '#contact' },
  { label: '採用情報', href: '#recruit' },
];
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto w-full max-w-5xl px-6 py-12">

    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">

      <!-- Logo & Address -->
      <div>
        <div class="h-8 w-32 rounded bg-slate-200 flex items-center justify-center text-xs text-slate-500 font-medium">
          LOGO
        </div>
        <address class="mt-4 not-italic text-xs leading-6 text-slate-500">
          〒XXX-XXXX 東京都◯◯区◯◯ X-X-X<br />
          TEL: 0X-XXXX-XXXX　FAX: 0X-XXXX-XXXX<br />
          MAIL: info@tomizawa.co.jp
        </address>
      </div>

      <!-- Nav -->
      <nav class="flex flex-wrap gap-x-6 gap-y-2">
        {navItems.map((item) => (
          <a href={item.href} class="text-xs text-slate-500 hover:text-slate-900">
            {item.label}
          </a>
        ))}
      </nav>

    </div>

    <p class="mt-8 text-center text-xs text-slate-400">
      &copy; {new Date().getFullYear()} 株式会社トミザワ All Rights Reserved.
    </p>

  </div>
</footer>
