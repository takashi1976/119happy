---
import SectionWrapper from './SectionWrapper.astro';

const problems = [
  {
    num: '1',
    text: '開業・独立にあたり、事務所の\n初期費用をできるだけ抑えたい。',
    keyword: '初期費用',
  },
  {
    num: '2',
    text: 'クライアントのプライバシーを保てる\nオフィスレイアウトにしたい。',
    keyword: 'プライバシー',
  },
  {
    num: '3',
    text: '書類が多く、限られたスペースに\n効率よく収納できていない。',
    keyword: '収納',
  },
  {
    num: '4',
    text: '通信回線・電気工事・内装工事など、\nどこへ頼めばいいかわからない。',
    keyword: '窓口の多さ',
  },
  {
    num: '5',
    text: '移転を検討しているが、本業が忙しくて\n事務所づくりに時間を割けない。',
    keyword: '時間がない',
  },
];
---

<SectionWrapper id="problem" bg="white" class="overflow-hidden bg-[#E5E6DF]+ !bg-gradient-to-b from-white to-slate-100">
  <img
    slot="background"
    src="/img/AdobeStock_1392396561.jpeg"
    class="absolute left-0 top-0 w-full opacity-40 mix-blend-multiply"
    alt=""
  />
  <div class="relative  w-full ">
    
 
    <div class="relative z-10 flex flex-col gap-10 lg:flex-col lg:items-start lg:gap-0">
      <div class="relative z-10 flex w-full max-w-full flex-col items-start">
    
        <div class="flex flex-wrap gap-3 relative z-10">
          <span class="inline-block rounded-full border border-[#457163] px-4 py-1 text-xs font-bold tracking-wider text-[#457163]">
            Problem
          </span>
          <span class="inline-block rounded-full border border-slate-400 px-4 py-1 text-xs font-bold tracking-wider text-slate-600">
            士業事務所のお悩み
          </span>
        </div>

        <h2 class="mt-6 text-center relative z-10 w-full text-3xl font-black leading-snug tracking-tight text-slate-900 md:text-5xl lg:text-6xl">
          こんなお悩み、
          <span class="text-[#457163]">ありませんか？</span>
        </h2>

        <p class="mt-5 max-w-full relative z-10 text-center w-full text-sm leading-7 text-slate-700 md:text-base lg:text-xl font-bold">
          士業事務所の新設・移転・レイアウト変更で、<br />実際によくいただくご相談をまとめました。
        </p>

        <img
          src="/img/nayami2.png"
          alt="悩んでいる様子のイラスト"
          class="mt-8 w-full relative z-10 max-w-[320px] mx-auto self-center lg:self-start"
        />
      </div>

      <ul class=" w-full grid grid-cols-2 gap-6 -mt-8 max-w-[900px] mx-auto relative z-20 ">
       
        {problems.map((p, index) => (
          <li class={`relative overflow-hidden_ rotate-2 rounded-2xl border border-slate-200/80 bg-slate-50 px-8 pl-24 py-6 shadow-md ${index === problems.length - 1 ? 'translate-x-1/2' : ''}`}>
            <p class="absolute h-full w-24 flex items-center justify-center left-0 top-0 text-7xl font-black leading-none select-none" style="font-family: 'Oswald', sans-serif;">
              <span class="text-transparent [-webkit-text-stroke:1.5px_rgba(69,113,99,0.50)]">{p.num}</span>
            </p>
            <span class="inline-flex  relative z-1   text-xl lg:text-2xl font-black tracking-wide text-[#457163]">
              #{p.keyword}
            </span>
            <p class="relative mt-0 whitespace-pre-line text-sm font-bold leading-6 text-slate-600 md:text-base">
              {p.text}
            </p>
          </li>
        ))}
      </ul>
    </div>
    <div class="relative z-20 mt-8 flex items-end justify-center w-full rounded-2xl bg-[#457163] px-6 py-7 pb-0 text-center text-white shadow-md lg:mt-12">
      <img src="/img/good1.png" alt="" class="w-48" />
      <div class="pb-9 w-full max-w-[400px] ">
        <p class="text-center text-lg font-black leading-snug md:text-2xl lg:text-3xl">
          そのお悩み、<br />
          オフィスレスキュー119 Happyが<br /><span class="px-1 text-[#E5E6DF]">まとめて解決</span>します。
        </p>

        <a
          href="#service"
          class="mt-5 pb-4 inline-flex items-center gap-2 rounded bg-white px-6 py-3 text-sm font-bold text-[#457163] transition-colors hover:bg-[#f6f7f3] lg:text-2xl"
        >
        無料相談・お見積り
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <img src="/img/good2.png" alt="" class="w-48" />
    </div>
  </div>
</SectionWrapper>
