---
import SectionWrapper from './SectionWrapper.astro';
import SectionHeading from './SectionHeading.astro';

const reasons = [
  {
    num: '01',
    title: '土壁専門の高い技術力',
    desc: '専門職人による確かな施工品質。どんな要望にも柔軟に対応します。',
  },
  {
    num: '02',
    title: 'トータルサポート体制',
    desc: '内装工事から移転手配・設備管理まで、一社完結でご対応可能です。',
  },
  {
    num: '03',
    title: '豊富な実績と信頼',
    desc: '多数の事務所移転・リノベーション実績。お客様の声が証明します。',
  },
  {
    num: '04',
    title: 'スピード対応',
    desc: 'タイトなスケジュールにも対応。お客様の事業継続を最優先に進めます。',
  },
];
---

<SectionWrapper id="reason" bg="gray">
  <SectionHeading title="当社を選ぶ理由" subtitle="Reason" />

  <div class="grid gap-6 md:grid-cols-2">
    {reasons.map((r) => (
      <div class="flex gap-5 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <span class="text-2xl font-bold text-slate-200">{r.num}</span>
        <div>
          <h3 class="text-base font-bold text-slate-900">{r.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{r.desc}</p>
        </div>
      </div>
    ))}
  </div>
</SectionWrapper>
