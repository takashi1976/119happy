---
import BuildingsDuotone from "phosphor-astro/BuildingsDuotone.astro";
import LightningDuotone from "phosphor-astro/LightningDuotone.astro";
import TrophyDuotone from "phosphor-astro/TrophyDuotone.astro";

const points = [
  {
    num: "01",
    text: '内装工事から家具の導入・買取<br />廃棄・引っ越しまで<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">トータル対応</strong>'
  },
  {
    num: "02",
    text: '<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">短納期・低コスト</strong>で<br />事務所家具を迅速に導入'
  },
  {
    num: "03",
    text: 'オフィス移転40年以上の<br /><strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">実績と信頼</strong>'
  }
];
---

<section class="bg-[#DDDBD6] h-full min-h-[800px] flex items-center">
  <div class="relative z-50 max-w-[1170px] mx-auto">
    <div class="relative inline-block mb-4 rotate-0">
      <div
        class="rounded-lg bg-white px-24 py-2 text-base text-red-500 tracking-widest border-2 font-black relative z-0"
      >
        士業専門
      </div>
    </div>
    <img
      src="/img/AdobeStock_684911866.jpeg"
      class="absolute right-0 rounded-none top-0 z-0 w-[77%] translate-x-1/4 translate-y-24"
    />
    <!-- バッジ -->
    <div class="relative z-10">
      <div
        class="flex flex-wrap gap-3 z-10 relative text-xl font-bold justify-start text-gray-700"
      >
        <p class="relative">
          <span class="inline-block scale-x-[-1]">/</span>
          <span class="px-2 leading-0 -pb-2 bg-red-200 inline-block">
            税理士、弁護士、司法書士の方へ
          </span>
          <span>/</span>
        </p>
      </div>

      <!-- メインヘッドライン -->
      <h1
        class="inline-block rleative z-10 mt-4 text-4xl font-black leading-snug tracking-tight text-slate-900 md:text-5xl/14"
      >
        事務所づくり、レイアウト変更、<br />引っ越しのトータルサービス
      </h1>

      <!-- サブヘッドライン -->
      <p
        class="mt-4 max-w-2xl text-base leading-8 text-slate-900 md:text-xl relative z-10"
      >
        物件選びから内装工事・家具の調達から廃棄・引っ越しまで、<br
          class="hidden md:block"
        />
        士業事務所の移転にかかわる<br /><strong
          class="text-lg lg:text-2xl! px-1 text-black marker font-black!"
        >
          全工程をワンストップで
        </strong>お引き受けします。
      </p>

      <!-- CTAボタン -->
      <div class="mt-9 flex flex-wrap gap-4">
        <a
          href="#contact"
          class="w-1/2 flex lg:min-w-80 text-center items-center gap-2 rounded bg-[#457163] px-8 lg:px-12 py-4 lg:py-7 text-sm lg:text-xl font-bold text-white shadow-md transition-colors hover:bg-[#365a4e]"
        >
          <span class="w-full">無料相談・お見積り</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 lg:size-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"
            >
            </path>
          </svg>
        </a>
      </div>
      <!-- 3カラムポイント -->
      <div class="mt-16 grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          points.map((p, i) => (
            <div class="relative shadow-md overflow- rounded-lg  border-slate-100 bg-slate-50 px-6 py-7">
              <span class="absolute top-4 right-5 text-4xl font-black text-[#B5C6C1] leading-none select-none">
                {p.num}
              </span>
              <div class=" absolute top-0 left-1/2 -translate-x-1/2  -mt-6 text-[#457163] flex justify-center  z-10 bg-[#E2E9E7] size-24 items-center  backdrop-blur-sm rounded-full -translate-y-4">
                {i === 0 && <BuildingsDuotone width={44} height={44} />}
                {i === 1 && <LightningDuotone width={44} height={44} />}
                {i === 2 && <TrophyDuotone width={44} height={44} />}
              </div>
              <p
                class="relative text-sm mt-10 lg:text-lg leading-7  font-black text-center"
                set:html={p.text}
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
