---
interface Props {
  title: string;
  subtitle: string;
  align?: 'left' | 'center';
}

const { title, subtitle, align = 'center' } = Astro.props;
const alignClass = align === 'center' ? 'text-center' : 'text-left';
---

<div class={`mb-12 ${alignClass}`}>
  <p class="text-xs font-semibold tracking-[0.3em] text-slate-400 uppercase">{subtitle}</p>
  <h2 class="mt-2 text-2xl font-bold tracking-tight text-slate-900 md:text-3xl">{title}</h2>
  <div class={`mt-3 h-0.5 w-10 bg-slate-900 ${align === 'center' ? 'mx-auto' : ''}`}></div>
</div>
