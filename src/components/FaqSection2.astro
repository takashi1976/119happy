---
const faqs = [
  {
    q: '対応エリアは？',
    a: '家具のご配送は全国対応いたします。内装工事や電気工事、お引越し作業は首都圏近郊にて対応致します。ご相談ください。',
  },
  {
    q: '急ぎの日程でも対応してくれますか？',
    a: '基本的にはお時間の余裕を持ってお問い合わせ下さい。急な場合でも在庫状況、配送状況で最短でご案内いたします。',
  },
  {
    q: '開業する事務所のレイアウトから相談したい。',
    a: 'もちろん可能です。現調にお伺いして無料で士業に合わせたレイアウトから作図、お見積りもいたします。',
  },
  {
    q: '使用中の事務所に会議室を作りたいです。',
    a: '会議室・応接ルーム・接客スペース、オフィスの間仕切りもお任せ下さい。用途に合わせてアルミ・スチールパネル、ガラスパネル、カラーバリエーションも豊富で工事作業もスピーディーです。土日の工事も行っていますのでご相談ください。',
  },
  {
    q: '電話やLAN配線、電源コンセントの増設などできますか？',
    a: '弊社には資格をもった専門の工事部隊がいます。通信・電気関係の工事はもちろん、ビジネスホン・複合機・光回線のお取り扱いもございます。',
  },
  {
    q: '事務所を移転するのですが、対応可能ですか。',
    a: '家具の引越作業から不要家具の買取・廃棄もお承りいたします。また、ご移転先の家具の納品もご一緒に一括対応可能です。',
  },
];
---

<section class="bg-[#F5F5F0] py-20">
  <div class="mx-auto w-full max-w-[800px] px-6">

    <p class="text-center text-xs font-bold tracking-widest text-[#457163] uppercase">FAQ</p>
    <h2 class="mt-2 text-center text-3xl font-black leading-snug tracking-tight text-slate-900 md:text-4xl">
      よくある<span class="text-[#457163]">ご質問</span>
    </h2>

    <dl class="mt-10 flex flex-col gap-3">
      {faqs.map((faq) => (
        <div
          x-data="{ open: false }"
          class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm"
        >
          <dt>
            <button
              type="button"
              class="flex w-full items-center justify-between px-6 py-5 text-left"
              @click="open = !open"
              :aria-expanded="open"
            >
              <span class="flex items-center gap-3">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#457163] text-xs font-black text-white">
                  Q
                </span>
                <span class="text-sm font-bold text-slate-900 md:text-base">{faq.q}</span>
              </span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 shrink-0 text-[#457163] transition-transform duration-200"
                :class="open ? 'rotate-180' : ''"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </dt>
          <dd
            x-show="open"
            x-transition:enter="transition-all duration-200 ease-out"
            x-transition:enter-start="opacity-0 -translate-y-1"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition-all duration-150 ease-in"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-1"
            x-cloak
            class="flex gap-3 border-t border-slate-100 px-6 py-5"
          >
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#457163]/10 text-xs font-black text-[#457163]">
              A
            </span>
            <p class="text-sm leading-7 text-slate-600 md:text-base">{faq.a}</p>
          </dd>
        </div>
      ))}
    </dl>

  </div>
</section>
