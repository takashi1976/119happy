---
import BuildingsDuotone from "phosphor-astro/BuildingsDuotone.astro";
import LightningDuotone from "phosphor-astro/LightningDuotone.astro";
import TrophyDuotone from "phosphor-astro/TrophyDuotone.astro";

const points = [
  {
    num: "01",
    text: '内装工事から家具の導入・買取<br />廃棄・引っ越しまで<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">トータル対応</strong>'
  },
  {
    num: "02",
    text: '<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">短納期・低コスト</strong>で<br />事務所家具を迅速に導入'
  },
  {
    num: "03",
    text: 'オフィス移転40年以上の<br /><strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">実績と信頼</strong>'
  }
];
---

<section class="bg-[#E5E6DF] h-full min-h-[800px]">
  <!-- アナウンスバー -->
  <div class="bg-[#457163] py-3 text-center hidden">
    <p class="text-sm font-semibold text-white tracking-wide">
      税理士・弁護士・司法書士の先生専門のオフィス移転サービス
    </p>
  </div>

  <!-- メインコンテンツ -->
  <div class="mx-auto w-full max-w-[1170px] px-6 pt-16 pb-20 relative">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute flex items-start top-7 h-full right-0 z-1 w-full max-w-[990px] translate-x-1/6"
      style="aspect-ratio: 500 / 331;"
    >
      <div
        class="h-full bottom-4 right-4 w-full -translate-y-1/8 z-0"
        style="
        background-image: url('/img/bg_original.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        -webkit-mask-image: url('/img/shape2.svg');
        mask-image: url('/img/shape2.svg');
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
        -webkit-mask-size: 88%;
        mask-size: 88%;
        -webkit-mask-mode: alpha;
        mask-mode: alpha;
      "
      >
      </div>
    </div>
    <div class="relative z-50">
      <!-- バッジ -->
      <div
        class="flex flex-wrap gap-3 z-10 relative text-xl font-bold justify-start text-gray-700"
      >
        <p class="relative">
          <img
            src="/img/senmon2.png"
            alt=""
            class="w-24 absolute top-0 left-4 -translate-x-full -translate-y-full m-rotate-10"
          />
          <span class="inline-block scale-x-[-1]">/</span>
          <span class="px-2 leading-0 -pb-2 bg-red-200 inline-block">
            税理士、弁護士、司法書士の方へ
          </span>
          <span>/</span>
        </p>
      </div>

      <!-- メインヘッドライン -->
      <h1
        class="inline-block mt-2 text-4xl font-black leading-snug tracking-tight text-slate-900 md:text-6xl"
      >
        移転も内装も、<br />
        <span class="text-[#457163]">すべて一社で完結。</span>
      </h1>

      <!-- サブヘッドライン -->
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-900 md:text-xl">
        物件選びから内装工事・家具の調達から廃棄・引っ越しまで、<br
          class="hidden md:block"
        />
        士業事務所の移転にかかわる<br /><strong
          class="text-lg lg:text-2xl! px-1 text-black marker font-black!"
        >
          全工程をワンストップで
        </strong>お引き受けします。
      </p>

      <!-- CTAボタン -->
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#contact"
          class="inline-flex lg:min-w-80 text-center items-center gap-2 rounded bg-[#457163] px-8 lg:px-12 py-4 lg:py-6 text-sm lg:text-xl font-bold text-white shadow-md transition-colors hover:bg-[#365a4e]"
        >
          <span class="w-full">無料相談・お見積り</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 lg:size-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"
            >
            </path>
          </svg>
        </a>
      </div>

      <!-- 3カラムポイント -->
      <div class="mt-16 grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          points.map((p, i) => (
            <div class="relative shadow-md overflow-hidden rounded-xl border border-slate-100 bg-slate-50 px-6 py-7">
              <span class="absolute top-4 right-5 text-4xl font-black text-slate-200 leading-none select-none">
                {p.num}
              </span>
              <div class="mb-3 text-[#457163] flex justify-center">
                {i === 0 && <BuildingsDuotone width={44} height={44} />}
                {i === 1 && <LightningDuotone width={44} height={44} />}
                {i === 2 && <TrophyDuotone width={44} height={44} />}
              </div>
              <p
                class="relative text-sm lg:text-base leading-7 text-slate-900 font-bold text-center"
                set:html={p.text}
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
