---
import BuildingsDuotone from "phosphor-astro/BuildingsDuotone.astro";
import LightningDuotone from "phosphor-astro/LightningDuotone.astro";
import TrophyDuotone from "phosphor-astro/TrophyDuotone.astro";

const points2 = [
  {
    iconPath:
      "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
    text: '内装工事から家具の導入・買取・廃棄・<br />引っ越しまで<span class="text-[#7BB2A2]">トータル対応可能</span>'
  },
  {
    iconPath: "M13 10V3L4 14h7v7l9-11h-7z",
    text: '<span class="text-[#7BB2A2]">短納期、低単価</span>で事務所家具の導入可能'
  },
  {
    iconPath:
      "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
    text: 'オフィス移転事業<span class="text-[#7BB2A2]">40年以上の実績と信頼</span>'
  }
];

const points = [
  {
    num: "01",
    text: '内装工事から家具の導入・買取<br />廃棄・引っ越しまで<strong class="marker text-lg lg:text-lg! px-1 text-black font-black!">トータル対応</strong>'
  },
  {
    num: "02",
    text: '<strong class="marker text-lg lg:text-lg! px-1 text-black font-black!">短納期・低コスト</strong>で<br />事務所家具を迅速に導入'
  },
  {
    num: "03",
    text: 'オフィス移転40年以上の<br /><strong class="marker text-lg lg:text-lg! px-1 text-black font-black!">実績と信頼</strong>'
  }
];
---

<section
  class="relative h-svh min-h-svh- max-h-[900px] overflow-hidden- bg-[#E5E6DF] flex items-center w-full"
>
  <div
    class="absolute inset-0 flex max-w-[1720px] mx-auto items-center justify-center z-0 w-full h-full"
  >
    <div
      class="w-100 bg-[#DDD6C8] absolute right-0 top-16 h-auto aspect-video z-0"
    >
    </div>
    <div
      class="w-82 !bg-[#DDD6C8]/100 absolute left-0 -bottom-0 translate-y-[0%] h-auto aspect-[1/1] z-0"
    >
    </div>
    <div
      class="relative w-[98%] xl:w-4/5 2xl:w-2/3 aspect-1683/948 overflow- flex items-center justify-center"
    >
      <div
        class="absolute top-0 left-0 borer-4 w-full h-full -translate-x-[10%] 2xl:-translate-x-[15%] pt-0 pb-0 flex items-center"
      >
        <div class="relative z-50">
          <div
            class="flex flex-wrap gap-3 z-10 relative text-3xl font-bold justify-start text-gray-700 mb-4"
          >
            <div class="relative bg-[#466C61] p-4 px-6 z-10 rounded-none">
              <p class="px-2 leading-0 -pb-2 inline-block text-white relative">
                税理士、弁護士、司法書士の方へ
              </p>
            </div>
          </div>

          <h1
            class="bg-white scale-80 -translate-x-[10%] font-noto p-6 py-9 text-4xl font-black leading-snug tracking-tight inline-block text-slate-900 md:text-5xl/19 relative z-0"
          >
            <div
              class="absolute overflow-hidden z-30 w-44 h-44 -top-1 -left-1 w"
            >
              <div
                class="w-64 font-black h-14 shadow-md flex items-center justify-center bg-gradient-to-br from-red-500 to-orange-700 text-white text-center absolute top-0 left-0 z-20 pl-4 -rotate-38 -translate-x-20 translate-y-6 tracking-wider text-2xl"
              >
                士業専門
              </div>
            </div>

            <span
              class="text-black bg-white pl-20 pr-12 z-10 relative rounded-sm inline-block"
            >
              事務所づくり、レイアウト変更、
            </span>
            <span class="text-[#7BB2A2] bg-white pl-20 pr-12 block">
              引っ越しのトータルサービス
            </span>
          </h1>
          <div
            class="description flex flex-col gap-1 items-start text-xl/10 tracking-widest"
          >
            <p
              class="mt-5 font-bold bg-white/0 text-black px-8- pt-4_ inline-block"
            >
              士業事務所の開業から内装工事・レイアウトや
            </p>
            <p
              class="2 mt-0 font-bold bg-white/0 text-black px-8- inline-block"
            >
              家具のご提案廃棄・ 引っ越しまで。
            </p>
            <p
              class="t mt-0 font-bold bg-white/0 text-black px--8 pb-4_ inline-block"
            >
              全工程をワンストップでお引き受けします
            </p>
          </div>
        </div>
      </div>

      <div
        class="strong translate-x-[10%] 2xl:translate-x-[20%] translate-y-[40%] max-w-[1100px] min-w-[1000px] grid grid-cols-1 w-4/5 place-self-end- object-cover gap-4 auto-rows-max items-start md:grid-cols-3 absolute bottom-0 z-50 right-0 mx-auto"
      >
        {
          points.map((p, i) => (
            <div class="gaga self-start h-fit relative  overflow- rounded-none  border-slate-100 bg-slate-50 px-4 py-7">
              <span class="absolute top-4 right-5 text-4xl font-black text-[#B5C6C1] leading-none select-none">
                {p.num}
              </span>

              <div class=" absolute top-0 left-1/2 -translate-x-1/2  -mt-6 text-[#7BB2A2] flex justify-center  z-10 bg-[#E2E9E7] size-24 items-center  backdrop-blur-sm rounded-full -translate-y-4">
                {i === 0 && <BuildingsDuotone width={44} height={44} />}
                {i === 1 && <LightningDuotone width={44} height={44} />}
                {i === 2 && <TrophyDuotone width={44} height={44} />}
              </div>
              <p
                class="relative text-sm mt-9 lg:text-base leading-7  font-black text-center"
                set:html={p.text}
              />
            </div>
          ))
        }
      </div>
      <img
        src="/img/AdobeStock_684911866.jpeg"
        alt=""
        aria-hidden="true"
        class="h-full w-full object-cover"
      />
    </div>
  </div>
</section>
