---
const navItems = [
  { label: '施工実績', href: '#works' },
  { label: '採用情報', href: '#recruit' },
  { label: 'お問い合わせ', href: '#contact' },
];
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex h-16 w-full max-w-5xl items-center justify-between px-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <div class="h-8 w-32 rounded bg-slate-200 flex items-center justify-center text-xs text-slate-500 font-medium">
        LOGO
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-8 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium text-slate-700 transition-colors hover:text-slate-900"
        >
          {item.label}
        </a>
      ))}
      <a
        href="#contact"
        class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-700"
      >
        無料相談
      </a>
    </nav>

    <!-- Mobile Hamburger -->
    <button
      class="flex items-center justify-center rounded p-2 md:hidden"
      x-data
      @click="$dispatch('toggle-menu')"
      aria-label="メニューを開く"
    >
      <span class="block h-0.5 w-5 bg-slate-900 before:block before:h-0.5 before:w-5 before:-translate-y-1.5 before:bg-slate-900 after:block after:h-0.5 after:w-5 after:translate-y-1 after:bg-slate-900"></span>
    </button>

  </div>
</header>
