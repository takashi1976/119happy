---
import SectionWrapper from './SectionWrapper.astro';
import SectionHeading from './SectionHeading.astro';

const features = [
  {
    num: '01',
    title: '工事用から管理まで一貫対応',
    desc: '事務所づくりの工事はもちろん、施工後のご包括的な管理が最大手でも対応。煩雑な調整をまとめてお引き受けします。',
  },
  {
    num: '02',
    title: 'オフィスレイアウトに特化',
    desc: 'オフィスレイアウトの設計・提案から施工まで専門チームが担当。お客様の働き方に合った空間づくりを実現します。',
  },
  {
    num: '03',
    title: '豊富な施工実績',
    desc: '大小さまざまな規模の施工実績を持つトミザワが、お客様のご要望に柔軟に対応します。',
  },
];
---

<SectionWrapper id="feature" bg="gray">
  <SectionHeading title="トミザワが選ばれる特徴" subtitle="Feature" />

  <div class="space-y-8">
    {features.map((f, i) => (
      <div class={`flex flex-col gap-6 md:flex-row ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
        <!-- Image placeholder -->
        <div class="flex h-52 w-full items-center justify-center rounded-xl bg-slate-200 text-sm text-slate-400 md:w-1/2">
          [施工・特徴イメージ {f.num}]
        </div>
        <!-- Text -->
        <div class="flex w-full flex-col justify-center md:w-1/2">
          <span class="text-xs font-bold tracking-[0.3em] text-slate-400">{f.num}</span>
          <h3 class="mt-2 text-xl font-bold text-slate-900">{f.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{f.desc}</p>
        </div>
      </div>
    ))}
  </div>
</SectionWrapper>
