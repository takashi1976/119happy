---
import SectionWrapper from "./SectionWrapper.astro";

const problems = [
  {
    num: "1",
    text: '開業・独立にあたり、事務所の初期費用を<strong class="marker text-lg lg:text-xl! px-1 text-black font-black! relative">できるだけ抑えたい</strong>。',
    keyword: "初期費用"
  },
  {
    num: "2",
    text: 'クライアントの<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">プライバシーを保てる</strong>オフィスレイアウトにしたい。',
    keyword: "プライバシー"
  },
  {
    num: "3",
    text: '書類が多く、限られたスペースに<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">効率よく収納できていない</strong>。',
    keyword: "収納"
  },
  {
    num: "4",
    text: '通信回線・電気工事・内装工事など、<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">どこへ頼めばいいか</strong>わからない。',
    keyword: "窓口の多さ"
  },
  {
    num: "5",
    text: '移転を検討しているが、本業が忙しくて事務所づくりに<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">時間を割けない</strong>。',
    keyword: "時間がない"
  }
];
---

<SectionWrapper id="problem" bg="white" class="overflow-hidden !bg-[#DDDBD6]/1">
  <div class="relative w-full">
    <div
      class="relative z-10 flex flex-col gap-10 lg:flex-col lg:items-start lg:gap-0"
    >
      <div class="relative z-10 flex w-full max-w-full flex-col items-start">
        <div class="flex flex-wrap justify-center mx-auto gap-3 relative z-10">
          <span
            class="inline-block rounded-full border border-[#457163] px-4 py-1 text-sm font-bold tracking-wider text-[#457163]"
          >
            Problem
          </span>
          <span
            class="inline-block rounded-full border border-slate-400 px-4 py-1 text-sm font-bold tracking-wider text-slate-600"
          >
            士業事務所のお悩み
          </span>
        </div>

        <h2
          class="mt-6 inline-block text-center relative z-10 w-full text-3xl font-black leading-snug tracking-tight text-slate-900 md:text-5xl lg:text-6xl"
        >
          こんなお悩み、
          <span class="text-[#457163]">ありませんか？</span>
        </h2>

        <p
          class="mt-5 inline-block w-auto relative z-10 text-center w-full text-sm text-slate-700 md:text-base lg:text-2xl/11 font-bold"
        >
          士業事務所の新設・移転・レイアウト変更で、<br
          />実際によくいただくご相談をまとめました。
        </p>
      </div>
      <div class="flex gap-20 w-full mt-8 lg:mt-16 relative">
        <div
          class="absolute top-0 left-0 w-full h-full z-0 bg-[#C7C4BB]/50 blur-3xl rounded-full scale-80"
        >
        </div>
        <img
          src="/img/nayami.png"
          alt="悩んでいる様子のイラスト"
          class="w-full relative z-10 max-w-[340px] mx-auto self-center lg:self-start"
        />
        <ul class="w-full grid grid-cols-1 gap-4 mx-auto relative z-20">
          {
            problems.map((p, index) => (
              <li
                class={`relative flex items-center  rounded-2xl border border-slate-200/80 bg-slate-50 px-6 pl-24 py-4 shadow-md `}
              >
                <p
                  class="absolute  h-full w-24 flex items-center justify-center text-[#457163] left-0 top-0 text-5xl font-black leading-none select-none"
                  style="font-family: 'Oswald', sans-serif;"
                >
                  <span class="">{p.num}</span>
                </p>

                <p
                  class="relative mt-0 text-sm font-bold leading-6 text-slate-600 md:text-base"
                  set:html={p.text}
                />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div
      class="relative z-20 mt-8 flex items-end justify-center w-full rounded-2xl bg-[#457163] px-6 py-7 pb-0 text-center text-white shadow-md lg:mt-12"
    >
      <img src="/img/good1.png" alt="" class="w-48" />
      <div class="pb-9 w-full max-w-[400px]">
        <p
          class="text-center text-lg font-black leading-snug md:text-2xl lg:text-3xl"
        >
          そのお悩み、<br />
          オフィスレスキュー119 Happyが<br /><span class="px-1 text-[#E5E6DF]">
            まとめて解決
          </span>します。
        </p>

        <a
          href="#service"
          class="mt-5 pb-4 inline-flex items-center gap-2 rounded bg-white px-6 py-3 text-sm font-bold text-[#457163] transition-colors hover:bg-[#f6f7f3] lg:text-2xl"
        >
          無料相談・お見積り
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"
            >
            </path>
          </svg>
        </a>
      </div>
      <img src="/img/good2.png" alt="" class="w-48" />
    </div>
  </div>
</SectionWrapper>
