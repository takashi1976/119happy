---
import SectionWrapper from "./SectionWrapper.astro";

const problems = [
  {
    num: "1",
    text: '開業・独立にあたり、事務所の初期費用を<strong class="marker text-lg lg:text-xl! px-1 text-black font-black! relative">できるだけ抑えたい</strong>。',
    keyword: "初期費用"
  },
  {
    num: "2",
    text: 'クライアントの<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">プライバシーを保てる</strong>オフィスレイアウトにしたい。',
    keyword: "プライバシー"
  },
  {
    num: "3",
    text: '書類が多く、限られたスペースに<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">効率よく収納できていない</strong>。',
    keyword: "収納"
  },
  {
    num: "4",
    text: '通信回線・電気工事・内装工事など、<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">どこへ頼めばいいか</strong>わからない。',
    keyword: "窓口の多さ"
  },
  {
    num: "5",
    text: '移転を検討しているが、本業が忙しくて事務所づくりに<strong class="marker text-lg lg:text-xl! px-1 text-black font-black!">時間を割けない</strong>。',
    keyword: "時間がない"
  }
];
---

<SectionWrapper
  id="problem"
  bg="white"
  class="overflow-hidden !bg-[#E5E6DF] border-t border-slate-200 relative"
>
  <div class="w-2/3 hidden absolute z-0 h-full bg-white top-0 left-0"></div>
  <div class="relative w-full">
    <div
      class="relative z-10 flex flex-col gap-10 lg:flex-col lg:items-start lg:gap-0"
    >
      <div class="relative z-10 flex w-full max-w-full flex-col items-start">
        <div class="flex flex-wrap justify-center mx-auto gap-3 relative z-10">
          <p
            class="text-3xl font-black leading-snug tracking-tight text-slate-900 md:text-5xl lg:text-3xl"
          >
            事務所づくり・新設・レイアウト変更・引っ越しで
          </p>
        </div>

        <h2
          class="mt-3 inline-block text-center relative z-10 w-full text-3xl font-black leading-snug tracking-tight text-slate-900 md:text-5xl lg:text-6xl"
        >
          こんなお悩み、
          <span class="text-[#457163]">ありませんか？</span>
        </h2>
      </div>
      <div
        class="flex gap-20 w-full mt-0 lg:mt-10 mb-4 relative max-w-screen-md mx-auto"
      >
        <ul class="w-full grid grid-cols-1 gap-7 mx-auto relative z-20">
          {
            problems.map((p, index) => (
              <li
                class={`relative flex items-center gap-3 rounded-2xl- border border-slate-200/80 bg-slate-50 px-6 py-4 shadow-md `}
              >
                <span
                  class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#457163] text-white"
                  aria-hidden="true"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.245 7.31a1 1 0 0 1-1.42 0L3.29 9.258a1 1 0 1 1 1.414-1.415l4.051 4.051 6.539-6.598a1 1 0 0 1 1.41-.006Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
                <p
                  class="relative mt-0 text-sm font-bold leading-6 text-slate-600 md:text-base"
                  set:html={p.text}
                />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div
      class="relative z-20 mt-8 flex items-end justify-center w-full rounded-none bg-[#457163] px-6 py-7 pb-0 text-center text-white shadow-md lg:mt-12"
    >
      <img src="/img/good1.png" alt="" class="w-48" />
      <div class="pb-9 w-full max-w-[400px]">
        <p
          class="text-center text-lg font-black leading-snug md:text-2xl lg:text-3xl"
        >
          そのお悩み、<br />
          オフィスレスキュー119 Happyが<br /><span class="px-1 text-[#E5E6DF]">
            まとめて解決
          </span>します。
        </p>

        <a
          href="#service"
          class="mt-5 pb-4 inline-flex items-center gap-2 rounded bg-white px-6 py-3 text-sm font-bold text-[#457163] transition-colors hover:bg-[#f6f7f3] lg:text-2xl"
        >
          無料相談・お見積り
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"
            >
            </path>
          </svg>
        </a>
      </div>
      <img src="/img/good2.png" alt="" class="w-48" />
    </div>
  </div>
</SectionWrapper>
